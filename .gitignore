# ─── Node.js Dependencies ─────────────────────────────────────────
# Never push node_modules — run `npm install` after cloning
node_modules/

# ─── Environment Variables ────────────────────────────────────────
# .env contains secrets (DB URI, JWT secret, etc.) — NEVER push this
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example IS tracked — it shows required variables without secrets

# ─── Log Files ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS & Editor Files ────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─── Build & Temp Files ───────────────────────────────────────────
dist/
build/
.cache/
*.tmp
*.temp
